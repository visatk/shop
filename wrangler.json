{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "idea",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "compatibility_date": "2026-04-12",
  "main": "./worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "marketplace_db",
      "database_id": "ef36ee8a-589e-48c0-81b3-111762912758"
    }
  ],
  "tail_consumers": [
    {
      "service": "tail-worker"
    }
  ],
  "r2_buckets": [
    {
      "binding": "DIGITAL_ASSETS",
      "bucket_name": "digital-goods"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "CACHE_KV",
      "id": "4364507baf164d75999e9c8fa4363488"
    }
  ]
}
